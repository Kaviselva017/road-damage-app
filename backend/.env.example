# Core
APP_ENV=development
APP_VERSION=1.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Supabase (database + storage + realtime)
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret
SUPABASE_ANON_KEY=your-anon-public-key

# Firebase Authentication
FIREBASE_PROJECT_ID=your-firebase-project-id
# For local dev: path to JSON file
# FIREBASE_SERVICE_ACCOUNT_PATH=backend/firebase-service-account.json
# For production (Render): base64-encoded JSON
# FIREBASE_SERVICE_ACCOUNT_JSON=base64encodedstring

# AI model
YOLO_MODEL_PATH=ai_model/best.pt
YOLO_CONFIDENCE_THRESHOLD=0.60
MAX_UPLOAD_SIZE_MB=10

# Cache (Upstash Redis — free tier)
# Get URL from: upstash.com → Create Database → REST URL (use rediss://)
REDIS_URL=

# Email (Resend — 3000 emails/month free)
# Get key from: resend.com → API Keys
RESEND_API_KEY=

# Observability (Sentry — 5000 events/month free)
# Get DSN from: sentry.io → Project → Settings → SDK Setup
SENTRY_DSN=

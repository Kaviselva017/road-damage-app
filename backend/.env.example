# ── ROADWATCH CORE ──────────────────────────────────────────────
APP_ENV=development
APP_VERSION=2.2.0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
BASE_URL=https://road-damage-appsystem.onrender.com

# ── DATABASE ────────────────────────────────────────────────────
# PostgreSQL + PostGIS (External URL from Supabase/Neon/Render)
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# ── SUPABASE INTEGRATION ────────────────────────────────────────
# Required for Realtime & Database functions
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret
SUPABASE_ANON_KEY=your-anon-public-key

# ── AUTHENTICATION ──────────────────────────────────────────────
# Firebase Project ID
FIREBASE_PROJECT_ID=your-firebase-project-id
# JSON credentials base64 encoded (recommended for production)
FIREBASE_SERVICE_ACCOUNT_JSON=
# Path to service account file (standard for local dev)
FIREBASE_SERVICE_ACCOUNT_PATH=backend/firebase-service-account.json

# ── AI MODEL & INFERENCE ────────────────────────────────────────
YOLO_MODEL_PATH=ai_model/best.pt
YOLO_CONFIDENCE_THRESHOLD=0.60
MAX_UPLOAD_SIZE_MB=10
USE_ONNX=false
# Set USE_ONNX=true to auto-export .pt → .onnx on first startup
# ONNX gives ~3x faster CPU inference, no GPU required
CLAHE_ENABLED=true
TTA_ENABLED=false
CLAHE_CLIP_LIMIT=2.0
CLAHE_GRID_SIZE=8

# ── STORAGE (S3 COMPATIBLE) ─────────────────────────────────────
# Cloudflare R2, AWS S3, or Backblaze B2
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
# Local upload dir (fallback if S3 is not configured)
UPLOAD_DIR=uploads

# ── REALTIME & CACHING (REDIS) ──────────────────────────────────
# Upstash Redis or standard Redis
REDIS_URL=rediss://:password@endpoint.upstash.io:6379

# ── NOTIFICATIONS & MAILING ─────────────────────────────────────
# Resend API Key for automated status emails
RESEND_API_KEY=re_xxxxxx
# FCM Sender ID for push notifications
FIREBASE_SENDER_ID=

# ── OBSERVABILITY & MONITORING ──────────────────────────────────
# Sentry DSN for error tracking
SENTRY_DSN=https://xxxx@sentry.io/xxxx
# Enable Prometheus /metrics endpoint (true/false)
ENABLE_METRICS=true

# ── DEPLOYMENT ──────────────────────────────────────────────────
# Render Deploy Hook URL for automated CI/CD
RENDER_DEPLOY_HOOK_URL=https://api.render.com/deploy/srv-xxxx?key=xxxx

USE_CELERY=false
# Set USE_CELERY=true when Celery worker is running
# Flower monitoring UI: http://localhost:5555

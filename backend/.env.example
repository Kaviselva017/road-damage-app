# Database
DATABASE_URL=postgresql://user:password@localhost:5432/road_damage_db

# Security
APP_ENV=development
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:3000,http://localhost:3000

# File Storage
UPLOAD_DIR=uploads

# AI Model
# YOLOv8 model path (relative to backend/ directory, or absolute)
YOLO_MODEL_PATH=../ai_model/road_damage_yolov8.pt

# Email / Notifications
# Prefer Resend in hosted environments. SMTP is an optional local fallback.
RESEND_API_KEY=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
ADMIN_EMAIL=
BASE_URL=http://localhost:8000

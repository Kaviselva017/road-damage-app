# Database
DATABASE_URL=postgresql://user:password@localhost:5432/road_damage_db
REDIS_URL=redis://localhost:6379/0

# Security
APP_ENV=development
APP_VERSION=1.0.0
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=https://your-dashboard.onrender.com,https://your-app.com
SENTRY_DSN=

# File Storage
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
S3_BUCKET_NAME=
S3_ENDPOINT_URL=       # leave blank for AWS, set for Cloudflare R2
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=

RATE_LIMIT_SUBMIT=10/minute
RATE_LIMIT_AUTH=20/minute

# AI Model
# YOLOv8 model path (relative to backend/ directory, or absolute)
YOLO_MODEL_PATH=../ai_model/road_damage_yolov8.pt
YOLO_CONFIDENCE_THRESHOLD=0.60

# Email / Notifications
# Prefer Resend in hosted environments. SMTP is an optional local fallback.
RESEND_API_KEY=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
ADMIN_EMAIL=
BASE_URL=http://localhost:8000
FIREBASE_SERVICE_ACCOUNT_JSON=   # base64 of service account JSON (Render)
FIREBASE_SERVICE_ACCOUNT_PATH=backend/firebase-service-account.json
SENTRY_DSN=
APP_VERSION=1.0.0
